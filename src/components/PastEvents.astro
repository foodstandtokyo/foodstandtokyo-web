---
import { getFeaturedEvents, getSiteSettings } from '../lib/microcms';

let events: Awaited<ReturnType<typeof getFeaturedEvents>> = [];
let totalEvents = '500+';
let prefectureCount = 5;
let brandCount = 4;

try {
  events = await getFeaturedEvents();
} catch (e) {
  console.error('イベント取得失敗:', e);
}
try {
  const site = await getSiteSettings();
  if (site.totalEvents) totalEvents = site.totalEvents;
  if (site.prefectureCount !== undefined) prefectureCount = site.prefectureCount;
  if (site.brandCount !== undefined) brandCount = site.brandCount;
} catch (e) {
  console.error('サイト設定取得失敗:', e);
}

// 統計数字を「数字部分」と「+などの記号部分」に分離（500+ → 500 と + に）
function splitNumber(text: string): { num: string; suffix: string } {
  const match = text.match(/^(\d+)(.*)$/);
  if (!match) return { num: text, suffix: '' };
  return { num: match[1], suffix: match[2] };
}
const eventsStat = splitNumber(totalEvents);
---

<section class="events fade-in" id="events">
  <div class="container">
    <div class="section-label">
      <div class="section-label-num">04</div>
      <div class="section-label-line"></div>
      <div class="section-label-name">PAST EVENTS</div>
    </div>

    <h2 class="big-title events-title">
      <span class="big-title-italic">Trusted</span><br />
      at events.
    </h2>
    <div class="jp-sub">これまでの出店実績</div>

    <div class="stats">
      <div class="stat-card">
        <div class="stat-num">{eventsStat.num}{eventsStat.suffix && <span class="plus">{eventsStat.suffix}</span>}</div>
        <div class="stat-label">EVENTS</div>
        <div class="stat-jp">出店件数</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{prefectureCount}</div>
        <div class="stat-label">PREF.</div>
        <div class="stat-jp">対応エリア</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{brandCount}</div>
        <div class="stat-label">BRANDS</div>
        <div class="stat-jp">ブランド数</div>
      </div>
    </div>

    <div class="events-heading">SELECTED VENUES</div>

    <div class="events-list">
      {events.map((event) => (
        <div class="event-item">
          <div class="event-image">
            {event.photo ? (
              <img src={event.photo.url} class="event-photo" alt={event.name} />
            ) : (
              <div class="event-image-text">EVENT<br />PHOTO</div>
            )}
          </div>
          <div class="event-content">
            <div class="event-name">{event.name}</div>
          </div>
        </div>
      ))}
    </div>

    <a href="#contact" class="more-events">
      VIEW ALL EVENTS <span class="arrow">→</span>
    </a>
  </div>
</section>


---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { brands } from '../../data/brands.js';

export function getStaticPaths() {
  return Object.values(brands).map((brand) => ({
    params: { id: brand.id },
    props: { brand },
  }));
}

const { brand } = Astro.props;
---

<BaseLayout title={`${brand.name} | FOOD STAND`}>
  <Header />
  <main>
    <!-- ヒーロー -->
    <section class="brand-hero" style={`background: ${brand.hero_bg}`}>
      <a href="/" class="back-link">
        <span class="arrow">←</span> BACK
      </a>
      <div class="brand-meta">
        <div class="brand-meta-num">{brand.num}</div>
        <div class="brand-meta-cat">{brand.category}</div>
      </div>
      <div class="hero-photo-label">
        [ HERO PHOTO ]
        <div class="hero-photo-label-jp">※{brand.name}の写真</div>
      </div>
      <div class="brand-name-block">
        <img src={brand.logo} class="brand-logo" alt={brand.name} />
        <div class="brand-name-jp">{brand.name_jp}</div>
      </div>
    </section>

    <!-- About this brand -->
    <section class="about-brand fade-in">
      <div class="container">
        <div class="about-label">ABOUT</div>
        <p class="about-text">{brand.about}</p>
      </div>
    </section>

    <!-- Menu Lineup -->
    <section class="menu-section fade-in">
      <div class="container">
        <div class="menu-section-label">MENU LINEUP</div>
        <h2 class="menu-title">
          <span class="italic">{brand.menu_title_italic}</span><br />
          {brand.menu_title_rest}
        </h2>
        <div class="menu-title-jp">メニュー一覧</div>

        <div class="menu-list">
          {brand.items.map((item) => (
            <div class="menu-item">
              <div class="menu-item-image">
                <div class="menu-img-label">
                  [ MENU PHOTO ]
                  <div class="menu-img-label-jp">※写真</div>
                </div>
              </div>
              <div class="menu-item-body">
                <div class="menu-item-name" set:html={item.name}></div>
                <div class="menu-item-price">
                  {item.prices.map((p) => (
                    <div class="price-row">
                      <span class="price-label">{p.label}</span>
                      <span class="price-value">{p.value}</span>
                    </div>
                  ))}
                </div>
                <p class="menu-item-desc">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ブランド切り替え -->
    <section class="brand-switch">
      <div class="container">
        <div class="switch-label">OTHER BRANDS</div>
        <div class="switch-row">
          <a href={`/brands/${brand.prev.id}`} class="switch-prev">
            <span class="switch-arrow">←</span>
            <span>
              {brand.prev.name_small && <span class="italic">{brand.prev.name_small} </span>}
              {brand.prev.name_main}
            </span>
          </a>
          <a href={`/brands/${brand.next.id}`} class="switch-next">
            <span>
              {brand.next.name_small && <span class="italic">{brand.next.name_small} </span>}
              {brand.next.name_main}
            </span>
            <span class="switch-arrow">→</span>
          </a>
        </div>
        <a href="/#brands" class="switch-back-list">— BACK TO BRAND LIST</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .brand-hero {
    width: 100%;
    height: 520px;
    position: relative;
    overflow: hidden;
    margin-top: 60px;
  }
  .brand-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.25) 0%, transparent 45%),
      radial-gradient(circle at 80% 80%, rgba(0, 0, 0, 0.2) 0%, transparent 50%);
  }
  .brand-hero::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #FAFAF7);
    z-index: 5;
  }
  .back-link {
    position: absolute;
    top: 20px;
    left: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #FAFAF7;
    z-index: 10;
  }
  .back-link .arrow {
    font-size: 14px;
  }
  .brand-meta {
    position: absolute;
    top: 50px;
    right: 24px;
    text-align: right;
    z-index: 3;
  }
  .brand-meta-num {
    font-family: var(--font-serif-en);
    font-style: italic;
    font-size: 36px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1;
  }
  .brand-meta-cat {
    margin-top: 6px;
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.8);
  }
  .hero-photo-label {
    position: absolute;
    top: 50px;
    left: 24px;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 8px;
    letter-spacing: 0.25em;
    z-index: 3;
  }
  .hero-photo-label-jp {
    margin-top: 4px;
    font-family: var(--font-serif-jp);
    font-size: 10px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
  }
  .brand-name-block {
    position: absolute;
    bottom: 100px;
    left: 24px;
    right: 24px;
    z-index: 4;
    text-align: center;
  }
  .brand-logo {
    max-width: 78%;
    height: auto;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.2));
    margin: 0 auto;
  }
  .brand-name-jp {
    margin-top: 18px;
    font-family: var(--font-serif-jp);
    font-size: 12px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.15em;
  }

  .container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .about-brand {
    padding: 40px 0 24px;
  }
  .about-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
  }
  .about-label::before {
    content: '';
    flex: 0 0 24px;
    height: 1px;
    background: var(--color-bluegray-medium);
  }
  .about-text {
    font-family: var(--font-serif-jp);
    font-weight: 300;
    font-size: 13px;
    line-height: 2.0;
    color: var(--color-text);
    letter-spacing: 0.08em;
  }

  .menu-section {
    padding: 40px 0;
    border-top: 1px solid var(--color-border);
    margin-top: 16px;
  }
  .menu-section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
  }
  .menu-section-label::before {
    content: '';
    flex: 0 0 24px;
    height: 1px;
    background: var(--color-bluegray-medium);
  }
  .menu-title {
    font-family: var(--font-serif-en);
    font-weight: 400;
    font-size: 44px;
    line-height: 1.0;
    color: var(--color-text);
  }
  .menu-title .italic {
    font-style: italic;
    color: var(--color-bluegray-medium);
    font-weight: 300;
  }
  .menu-title-jp {
    margin-top: 10px;
    font-family: var(--font-serif-jp);
    font-size: 12px;
    color: var(--color-text-sub);
    letter-spacing: 0.15em;
  }
  .menu-list {
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .menu-item {
    background: #FFFFFF;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .menu-item-image {
    width: 100%;
    height: 220px;
    background: linear-gradient(135deg, #C5D1DC, #7A95AB);
    position: relative;
    overflow: hidden;
  }
  .menu-item-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.25), transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(0, 0, 0, 0.15), transparent 50%);
  }
  .menu-img-label {
    position: absolute;
    bottom: 14px;
    left: 14px;
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-sans);
    font-size: 8px;
    letter-spacing: 0.25em;
    z-index: 2;
  }
  .menu-img-label-jp {
    margin-top: 2px;
    font-family: var(--font-serif-jp);
    font-size: 9px;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 300;
  }
  .menu-item-body {
    padding: 22px 22px 24px;
  }
  .menu-item-name {
    font-family: var(--font-serif-jp);
    font-weight: 500;
    font-size: 22px;
    color: var(--color-text);
    letter-spacing: 0.05em;
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .menu-item-price {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .price-label {
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--color-text-sub);
  }
  .price-value {
    font-family: var(--font-serif-en);
    font-weight: 500;
    font-size: 18px;
    color: var(--color-bluegray-dark);
  }
  .menu-item-desc {
    font-family: var(--font-serif-jp);
    font-weight: 300;
    font-size: 12px;
    line-height: 1.85;
    color: #4A4A4A;
    letter-spacing: 0.05em;
  }

  .brand-switch {
    padding: 30px 0 60px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .switch-label {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
    margin-bottom: 16px;
  }
  .switch-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .switch-prev,
  .switch-next {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-serif-en);
    font-size: 18px;
    color: var(--color-text);
    font-weight: 400;
  }
  .switch-prev .italic,
  .switch-next .italic {
    font-style: italic;
    color: var(--color-bluegray-medium);
  }
  .switch-arrow {
    font-size: 16px;
    color: var(--color-bluegray-medium);
  }
  .switch-back-list {
    display: block;
    text-align: center;
    margin-top: 24px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-bluegray-medium);
  }
</style>

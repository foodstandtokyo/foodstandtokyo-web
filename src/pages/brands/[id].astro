---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllBrands, getMenuItemsByBrandId } from '../../lib/microcms';

export async function getStaticPaths() {
  const brands = await getAllBrands();

  // 各ブランドのメニューと、前後ブランドを計算
  const paths = await Promise.all(
    brands.map(async (brand, index) => {
      const menuItems = await getMenuItemsByBrandId(brand.id);

      // orderでソート済みの brands 配列から前後を計算
      const prevBrand = brands[(index - 1 + brands.length) % brands.length];
      const nextBrand = brands[(index + 1) % brands.length];

      return {
        params: { id: brand.slug },
        props: {
          brand,
          menuItems,
          prevBrand,
          nextBrand,
        },
      };
    })
  );

  return paths;
}

const { brand, menuItems, prevBrand, nextBrand } = Astro.props;

// 番号を 01, 02, 03... 形式にフォーマット
const num = String(brand.order).padStart(2, '0');
---

<BaseLayout title={`${brand.name} | FOOD STAND`}>
  <Header />
  <main>
    <!-- ヒーロー（映画ポスター風） -->
    <section class="brand-hero" style={`background: ${brand.heroBg}`}>
      {brand.heroImage ? (
        <img src={brand.heroImage.url} class="hero-photo" alt={brand.name} />
      ) : (
        <div class="hero-photo-label">
          [ HERO PHOTO ]
          <div class="hero-photo-label-jp">※{brand.name}の写真</div>
        </div>
      )}
      <a href="/" class="back-link">
        <span class="arrow">←</span> BACK
      </a>
      <div class="brand-meta">
        <div class="brand-meta-num">{num}</div>
        <div class="brand-meta-cat">{brand.category}</div>
      </div>
      <div class="brand-name-block">
        <img src={brand.logo.url} class="brand-logo" alt={brand.name} />
        <div class="brand-name-jp">{brand.subTitle}</div>
      </div>
    </section>

    <!-- About this brand -->
    <section class="about-brand fade-in">
      <div class="container">
        <div class="about-label">ABOUT</div>
        <p class="about-text">{brand.about}</p>
      </div>
    </section>

    <!-- Menu Lineup -->
    <section class="menu-section fade-in">
      <div class="container">
        <div class="menu-section-label">MENU LINEUP</div>
        <h2 class="menu-title">
          <span class="italic">{brand.menuTitleItalic}</span><br />
          {brand.menuTitleRest}
        </h2>
        <div class="menu-title-jp">メニュー一覧</div>

        <div class="menu-list">
          {menuItems.map((item) => (
            <div class="menu-item">
              <div class="menu-item-image">
                {item.image ? (
                  <img src={item.image.url} alt={item.name} class="menu-photo" />
                ) : (
                  <div class="menu-img-label">
                    [ MENU PHOTO ]
                    <div class="menu-img-label-jp">※写真</div>
                  </div>
                )}
              </div>
              <div class="menu-item-body">
                <div class="menu-item-name">{item.name}</div>
                <div class="menu-item-price">
                  <div class="price-row">
                    <span class="price-label">{item.priceLabel}</span>
                    <span class="price-value">{item.priceValue}</span>
                  </div>
                </div>
                <p class="menu-item-desc">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ブランド切り替え -->
    <section class="brand-switch">
      <div class="container">
        <div class="switch-label">OTHER BRANDS</div>
        <div class="switch-row">
          <a href={`/brands/${prevBrand.slug}`} class="switch-prev">
            <span class="switch-arrow">←</span>
            <span>{prevBrand.name}</span>
          </a>
          <a href={`/brands/${nextBrand.slug}`} class="switch-next">
            <span>{nextBrand.name}</span>
            <span class="switch-arrow">→</span>
          </a>
        </div>
        <a href="/#brands" class="switch-back-list">— BACK TO BRAND LIST</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .brand-hero {
    width: 100%;
    height: 480px;
    position: relative;
    overflow: hidden;
    margin-top: 60px;
  }
  /* 暗めオーバーレイ（写真がない時はそのまま透けて、写真がある時はシネマティックに暗くする） */
  .brand-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(20, 35, 50, 0.45) 0%,
      rgba(20, 35, 50, 0.30) 40%,
      rgba(20, 35, 50, 0.55) 100%
    );
    z-index: 2;
    pointer-events: none;
  }
  /* 下端のページとの境目フェード */
  .brand-hero::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, #FAFAF7);
    z-index: 6;
  }
  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    /* 軽くぼかして主役を白ロゴに */
    filter: brightness(0.85);
  }
  .back-link {
    position: absolute;
    top: 20px;
    left: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #FAFAF7;
    z-index: 10;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .back-link .arrow {
    font-size: 14px;
  }
  .brand-meta {
    position: absolute;
    top: 24px;
    right: 24px;
    text-align: right;
    z-index: 5;
  }
  .brand-meta-num {
    font-family: var(--font-serif-en);
    font-style: italic;
    font-size: 36px;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
  }
  .brand-meta-cat {
    margin-top: 6px;
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }
  .hero-photo-label {
    position: absolute;
    bottom: 100px;
    left: 24px;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-sans);
    font-size: 8px;
    letter-spacing: 0.25em;
    z-index: 3;
  }
  .hero-photo-label-jp {
    margin-top: 4px;
    font-family: var(--font-serif-jp);
    font-size: 10px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
  }
  /* ブランド名ブロック：中央配置でポスター感 */
  .brand-name-block {
    position: absolute;
    top: 50%;
    left: 24px;
    right: 24px;
    transform: translateY(-50%);
    z-index: 5;
    text-align: center;
  }
  .brand-logo {
    max-width: 78%;
    height: auto;
    filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.45));
    margin: 0 auto;
  }
  .brand-name-jp {
    margin-top: 22px;
    font-family: var(--font-serif-jp);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.18em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  .container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .about-brand {
    padding: 40px 0 24px;
  }
  .about-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
  }
  .about-label::before {
    content: '';
    flex: 0 0 24px;
    height: 1px;
    background: var(--color-bluegray-medium);
  }
  .about-text {
    font-family: var(--font-serif-jp);
    font-weight: 300;
    font-size: 13px;
    line-height: 2.0;
    color: var(--color-text);
    letter-spacing: 0.08em;
    white-space: pre-wrap;
  }

  .menu-section {
    padding: 40px 0;
    border-top: 1px solid var(--color-border);
    margin-top: 16px;
  }
  .menu-section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
  }
  .menu-section-label::before {
    content: '';
    flex: 0 0 24px;
    height: 1px;
    background: var(--color-bluegray-medium);
  }
  .menu-title {
    font-family: var(--font-serif-en);
    font-weight: 400;
    font-size: 44px;
    line-height: 1.0;
    color: var(--color-text);
  }
  .menu-title .italic {
    font-style: italic;
    color: var(--color-bluegray-medium);
    font-weight: 300;
  }
  .menu-title-jp {
    margin-top: 10px;
    font-family: var(--font-serif-jp);
    font-size: 12px;
    color: var(--color-text-sub);
    letter-spacing: 0.15em;
  }
  .menu-list {
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .menu-item {
    background: #FFFFFF;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .menu-item-image {
    width: 100%;
    height: 220px;
    background: linear-gradient(135deg, #C5D1DC, #7A95AB);
    position: relative;
    overflow: hidden;
  }
  .menu-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .menu-item-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.25), transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(0, 0, 0, 0.15), transparent 50%);
    pointer-events: none;
  }
  .menu-img-label {
    position: absolute;
    bottom: 14px;
    left: 14px;
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-sans);
    font-size: 8px;
    letter-spacing: 0.25em;
    z-index: 2;
  }
  .menu-img-label-jp {
    margin-top: 2px;
    font-family: var(--font-serif-jp);
    font-size: 9px;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 300;
  }
  .menu-item-body {
    padding: 22px 22px 24px;
  }
  .menu-item-name {
    font-family: var(--font-serif-jp);
    font-weight: 500;
    font-size: 22px;
    color: var(--color-text);
    letter-spacing: 0.05em;
    line-height: 1.3;
    margin-bottom: 14px;
  }
  .menu-item-price {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .price-label {
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--color-text-sub);
  }
  .price-value {
    font-family: var(--font-serif-en);
    font-weight: 500;
    font-size: 18px;
    color: var(--color-bluegray-dark);
  }
  .menu-item-desc {
    font-family: var(--font-serif-jp);
    font-weight: 300;
    font-size: 12px;
    line-height: 1.85;
    color: #4A4A4A;
    letter-spacing: 0.05em;
  }

  .brand-switch {
    padding: 30px 0 60px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .switch-label {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--color-bluegray-medium);
    margin-bottom: 16px;
  }
  .switch-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .switch-prev,
  .switch-next {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-serif-en);
    font-size: 18px;
    color: var(--color-text);
    font-weight: 400;
  }
  .switch-arrow {
    font-size: 16px;
    color: var(--color-bluegray-medium);
  }
  .switch-back-list {
    display: block;
    text-align: center;
    margin-top: 24px;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--color-bluegray-medium);
  }
</style>
